# Kavach — Environment Variables
# Copy to .env.local for development. NEVER commit .env files with real values.
# Production secrets must be stored in AWS Secrets Manager.

# Database (PostgreSQL)
DATABASE_URL=postgresql://kavach:kavach@localhost:5432/kavach_dev

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_APP_SECRET=your_app_secret_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here

# AWS
AWS_REGION=ap-south-1
AWS_S3_BUCKET=kavach-records-dev
# In production: use IAM instance profile, not static keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# AI / LLM (choose one provider)
EXTRACTION_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# OCR provider
OCR_PROVIDER=aws-textract
# OCR_PROVIDER=google-cloud-vision
# GOOGLE_CLOUD_VISION_CREDENTIALS_PATH=./credentials.json

# Redis (for BullMQ queue + WhatsApp conversation state)
REDIS_URL=redis://localhost:6379

# Auth / Session
SESSION_SECRET=minimum_32_chars_random_secret_here
SESSION_COOKIE_NAME=kavach_session
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OTP (SMS delivery)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Confidence threshold (PROVISIONAL — calibrate with real data)
EXTRACTION_CONFIDENCE_THRESHOLD=0.85

# Portal link expiry (hours)
PORTAL_TOKEN_EXPIRY_HOURS=8
OTP_EXPIRY_MINUTES=10
